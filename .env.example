# Copy to .env and fill in real values. Never commit .env.
# Loaded by app.core.config.Settings via pydantic-settings.

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
APP_ENV=dev
APP_NAME=marketplace
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# ---------------------------------------------------------------------------
# Postgres (must match docker-compose.yml)
# ---------------------------------------------------------------------------
POSTGRES_USER=marketplace
POSTGRES_PASSWORD=marketplace_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=marketplace

# ---------------------------------------------------------------------------
# Auth — JWT sessions (15-min access + refresh)
# ---------------------------------------------------------------------------
JWT_SECRET=change-me-in-dev-and-always-rotate-in-prod
JWT_ALG=HS256
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30

# ---------------------------------------------------------------------------
# WebAuthn — Relying Party (passkeys)
# ---------------------------------------------------------------------------
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Marketplace V0
WEBAUTHN_ORIGIN=http://localhost:8000

# ---------------------------------------------------------------------------
# Anthropic — agent LLM
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ---------------------------------------------------------------------------
# OpenAI — embeddings only
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------------
# Self Protocol — ZK identity verifier (HTTP wrap, V0)
# ---------------------------------------------------------------------------
# Hosted verifier URL (default points at Self Labs). Override for self-hosted
# or for a local stub during integration tests.
SELF_VERIFIER_URL=https://api.self.xyz/v1/verify
# Scope determines the nullifier derivation: nullifier = hash(document, scope).
# Same user with same document on different scopes ⇒ different nullifiers
# (per-service sybil resistance). Don't change post-launch lightly.
SELF_VERIFIER_SCOPE=marketplace-it-v0
SELF_VERIFIER_TIMEOUT_SECONDS=10

# ---------------------------------------------------------------------------
# KMS — agent keypair custody (V0 stub: file under .secrets/)
# ---------------------------------------------------------------------------
KMS_KEYS_DIR=.secrets/agent_keys
