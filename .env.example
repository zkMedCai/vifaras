# Copy to .env and fill in real values. Never commit .env.
# Loaded by app.core.config.Settings via pydantic-settings.

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
APP_ENV=dev
APP_NAME=marketplace
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# ---------------------------------------------------------------------------
# Postgres (must match docker-compose.yml)
# ---------------------------------------------------------------------------
POSTGRES_USER=marketplace
POSTGRES_PASSWORD=marketplace_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=marketplace

# ---------------------------------------------------------------------------
# Auth — JWT sessions (15-min access + refresh)
# ---------------------------------------------------------------------------
JWT_SECRET=change-me-in-dev-and-always-rotate-in-prod
JWT_ALG=HS256
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30

# ---------------------------------------------------------------------------
# WebAuthn — Relying Party (passkeys)
# ---------------------------------------------------------------------------
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Marketplace V0
WEBAUTHN_ORIGIN=http://localhost:8000

# ---------------------------------------------------------------------------
# Anthropic — agent LLM
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ---------------------------------------------------------------------------
# OpenAI — embeddings only
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------------
# Self Protocol — ZK identity verifier (HTTP wrap, V0)
# ---------------------------------------------------------------------------
SELF_VERIFIER_URL=http://localhost:9000/verify
