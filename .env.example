# Copy to .env and fill in real values. Never commit .env.
# Loaded by app.core.config.Settings via pydantic-settings.

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
APP_ENV=dev
APP_NAME=marketplace
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

# ---------------------------------------------------------------------------
# Postgres (must match docker-compose.yml)
# ---------------------------------------------------------------------------
POSTGRES_USER=marketplace
POSTGRES_PASSWORD=marketplace_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=marketplace

# ---------------------------------------------------------------------------
# Auth — JWT sessions (15-min access + refresh)
# ---------------------------------------------------------------------------
JWT_SECRET_CURRENT=change-me-in-dev-and-always-rotate-in-prod
JWT_SECRET_PREVIOUS=
JWT_ALG=HS256
JWT_ACCESS_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=30

# ---------------------------------------------------------------------------
# WebAuthn — Relying Party (passkeys)
# ---------------------------------------------------------------------------
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Marketplace V0
WEBAUTHN_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------------------
# Anthropic — Vifaras-managed agent LLM
# V0 uses the marketplace's API account. Do not use Claude Pro/Max consumer
# session/OAuth credentials here.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
MATCHING_BACKEND=embedding
ANTHROPIC_MATCH_CANDIDATE_LIMIT=30
ANTHROPIC_MATCH_MAX_TOKENS=1000

# ---------------------------------------------------------------------------
# OpenAI — Vifaras-managed embeddings
# ChatGPT Plus/Pro billing is separate from API billing; use a Platform API key.
# Required only when MATCHING_BACKEND=embedding.
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BACKEND=openai

# ---------------------------------------------------------------------------
# Self Protocol — ZK identity verifier (HTTP wrap, V0)
# ---------------------------------------------------------------------------
# Hosted verifier URL (default points at Self Labs). Override for self-hosted
# or for a local stub during integration tests.
SELF_VERIFIER_URL=https://api.self.xyz/v1/verify
# Scope determines the nullifier derivation: nullifier = hash(document, scope).
# Same user with same document on different scopes ⇒ different nullifiers
# (per-service sybil resistance). Don't change post-launch lightly.
SELF_VERIFIER_SCOPE=marketplace-it-v0
SELF_VERIFIER_TIMEOUT_SECONDS=10

# ---------------------------------------------------------------------------
# KMS — agent keypair custody
# ---------------------------------------------------------------------------
# Required at startup. Generate with: openssl rand -base64 32
KMS_MASTER_KEY=

# ---------------------------------------------------------------------------
# Agent scheduler + LLM cost guardrails
# ---------------------------------------------------------------------------
# Keep disabled until Anthropic/OpenAI keys + billing/caps are intentionally set.
ENABLE_AGENT_SCHEDULER=false
ENABLE_RATE_LIMITING=false
ENABLE_DEV_ENDPOINTS=false
MAX_DAILY_LLM_COST_USD=50.0
DAILY_USER_COST_CAP_USD=0.50
AGENT_TICK_COST_CAP_USD=0.10
